NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# MongoDB (database name: eshop_online)
MONGO_URI=mongodb://127.0.0.1:27017/eshop_online
# Optional: standard connection string for Atlas (avoids SRV DNS issues on Windows)
MONGO_URI_STANDARD=

# JWT
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRE=15m
JWT_REFRESH_SECRET=your_jwt_refresh_secret_change_in_production
JWT_REFRESH_EXPIRE=7d

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=E-Shop Online

# Cloudinary (optional — falls back to local uploads if not set)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
